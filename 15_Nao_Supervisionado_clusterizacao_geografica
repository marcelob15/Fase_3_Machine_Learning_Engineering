import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import os
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
import time

start_time = time.time()

# Configurações de Diretório
base_dir = os.path.dirname(os.path.abspath(__file__))
output_dir = os.path.join(base_dir, 'img_nao_supervisionado')
os.makedirs(output_dir, exist_ok=True)

# 1. Carga do CSV Processado (Substituindo Parquet)
print("🌍 Carregando dados para Clusterização (CSV Otimizado)...")
flights_ready_path = os.path.join(base_dir, 'csv_processado', 'flights_ready.csv')

if not os.path.exists(flights_ready_path):
    print(f"❌ Erro: Arquivo {flights_ready_path} não encontrado.")
else:
    # Definindo dtypes para carregar apenas o necessário para a análise geográfica
    optimized_dtypes = {
        'LATITUDE': 'float32',
        'LONGITUDE': 'float32',
        'TARGET': 'int8',
        'DISTANCE': 'float32'
    }
    
    # Carregamos apenas as colunas que serão usadas no agrupamento e clusterização
    df = pd.read_csv(flights_ready_path, usecols=optimized_dtypes.keys(), dtype=optimized_dtypes)

    # 2. Agrupamento Geográfico para o K-Means
    print("🧹 Agrupando dados por coordenadas...")
    # Agrupamos por coordenadas para identificar "zonas de risco"
    df_geo = df.groupby(['LATITUDE', 'LONGITUDE']).agg({
        'TARGET': 'mean',         # Frequência de atrasos por aeroporto
        'DISTANCE': 'mean'        # Distância média das rotas
    }).reset_index()

    # 3. K-Means
    print("📌 Executando K-Means (Não Supervisionado)...")
    # Utilizamos Latitude, Longitude e a taxa de Target para criar os clusters
    X_clus = df_geo[['LATITUDE', 'LONGITUDE', 'TARGET']]
    scaler = StandardScaler()
    X_clus_scaled = scaler.fit_transform(X_clus)

    # Definimos 4 clusters para separar regiões/comportamentos de atraso
    kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
    df_geo['CLUSTER'] = kmeans.fit_predict(X_clus_scaled)

    # 4. Gráfico: Mapa de Clusters
    print("📊 Gerando mapa de clusters...")
    plt.figure(figsize=(12, 7))
    scatter = plt.scatter(df_geo['LONGITUDE'], df_geo['LATITUDE'], 
                c=df_geo['CLUSTER'], cmap='viridis', s=50, alpha=0.6, edgecolors='white')
    
    plt.colorbar(scatter, label='Cluster ID')
    plt.title('Clusters de Aeroportos por Risco Geográfico de Atraso', fontsize=14, fontweight='bold')
    plt.xlabel('Longitude')
    plt.ylabel('Latitude')
    plt.grid(True, linestyle='--', alpha=0.5)
    
    # Salvando o resultado
    output_path = os.path.join(output_dir, 'mapa_clusters_geograficos.png')
    plt.savefig(output_path, bbox_inches='tight')

    print(f"\n✨ Modelagem Não Supervisionada concluída! Imagens em: {output_dir}")
    print(f"⏱️ Tempo de execução da Modelagem: {time.time() - start_time:.2f} segundos")
    print("="*50)